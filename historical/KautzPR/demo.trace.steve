;; Trace the inference process.
;; Turn this off by skipping this command (hit "n"), or later by entering
;; the immediate command (ee "Don't trace.").

Command: (EE "Don't Trace.")y
  Translation: (SETQ *NOISY* NIL)
  NIL


Command: (EE "Clear the database.")y
  Translation: (CLEAR-ALL-MAPPINGS)
  EQUALP

;****************************************************
;* Hunt-rob-test                                    *
;*    demonstrates upward inference and matching,   *
;*    without parameters.                           *
;****************************************************

Command: (EE "Load file hunt-rob-test.")y
  Translation: (LOAD (MERGE-PATHNAMES hunt-rob-test *TEST-DIR*))
; Loading /u/sgwoods/Kautz/test/hunt-rob-test.lisp.

  T
;;
;; Multiple-Grouping Example.  Incremental algorithm finds one
;; solution, but the non-dichronic algorithm will find two.
;;
;;  INCREMENTAL version
;;

Command: (EE "Perform incremental updates.")y
  Translation: (SETQ *UPDATE-TYPE* 'INCREMENTAL)
  INCREMENTAL


Command: (EE "Initialize the hypothesis set.")y
  Translation: (INIT-HYPOTHS)
  (NIL)


Command: (EE "Joe gets a gun.")y
  Translation: (UPDATE '(GET-GUN (AGENT JOE)))
  NIL

Command: (EE "Show the hypothesis set in detail.")y
  Translation: (DISPLAY-HYPOTHS T)
********************************************************
|  There are 1 ways of grouping the observations
********************************************************

|  Hypthosis set 1 is (EG826)
|  where

======================================

graph EG826
END861 ((AGENT JOE))
      ?= HUNT877 ((AGENT JOE))
           S1 -> GET-GUN830 ((AGENT JOE))
      ?= ROB-BANK840 ((AGENT JOE))
           S1 -> GET-GUN830 ((AGENT JOE))  ^
  NIL

Command: (EE "Someone goes to the bank.")y
  Translation: (UPDATE '(GO-TO-BANK))
  NIL

Command: (EE "Show the hypothesis set in detail.")y
  Translation: (DISPLAY-HYPOTHS T)
