END1000 ((AGENT JOE))
      ?= ROB-BANK1020 ((AGENT JOE))
           S2 -> GO-TO-BANK1051 NIL
           S1 -> GET-GUN1036 ((AGENT JOE))
  NIL

Command: (EE "Someone goes to the woods.")y
  Translation: (UPDATE '(GO-TO-WOODS))
  NIL

