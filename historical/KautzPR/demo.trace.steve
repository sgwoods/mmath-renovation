;; You can try the other combinations!
;; End of language test.


;*******************************************************
;* Merge test: Demonstrates "collapsing" of search     *
;*    graph, during matching.  To understand this test,*
;*    try drawing the graphs. You will see a double    *
;*    diamond.  We can retain uncertainty in the top   *
;*    of the graph, even as lower level steps are      *
;*    disambiguated.                                   *
;*******************************************************


Command: (CLEAR-ALL-MAPPINGS)y

  EQUALP

Command: (LOAD (MERGE-PATHNAMES "merge-test" *TEST-DIR*))y

; Loading /u/sgwoods/Kautz/test/merge-test.lisp.

  T

Command: (EXPLAIN-OBSERVATION '(H) 'G1)y

  T
  H6849

Command: (DRAW-GRAPH T)y

graph G1
END6890 NIL
      ?= A6883 NIL
           ?= B6909 NIL
                S1 -> D6866 NIL
                     ?= E6948 NIL
                          S1 -> H6849 NIL
                     ?= F6856 NIL
                          S1 -> H6849 NIL  ^
           ?= C6873 NIL
                S1 -> D6866 NIL  ^
  (C6873 F6856 H6849 E6948 D6866 B6909 A6883 END6890)
;; Note the little ^ signs in the graph.  They indicate a reference to graph structure
;; which has been printed on a previous line.


Command: (EXPLAIN-OBSERVATION '(K) 'G2)y

  T
  K6975

Command: (DRAW-GRAPH T)y

graph G2
END7016 NIL
      ?= A7009 NIL
           ?= B7035 NIL
                S1 -> D6992 NIL
                     ?= F7074 NIL
                          S2 -> K6975 NIL
                     ?= G6982 NIL
                          S2 -> K6975 NIL  ^
           ?= C6999 NIL
                S1 -> D6992 NIL  ^
  (C6999 G6982 K6975 F7074 D6992 B7035 A7009 END7016)
;; Now matching g1 and g2 yields decision on F, but retains ambiguity between B and C

Command: (MATCH-GRAPHS 'G1 'G2 'G1+G2)y

  END7100


Command: (DRAW-GRAPH T)y

graph G1+G2
END7100 NIL
      ?= A7109 NIL
           ?= C7184 NIL
                S1 -> D7127 NIL
                     ?= F7136 NIL
                          S1 -> H7157 NIL
                          S2 -> K7145 NIL
           ?= B7118 NIL
                S1 -> D7127 NIL  ^
  (B7118 K7145 H7157 F7136 D7127 C7184 A7109 END7100)
;; end of merge test


