 -INF 4 -INF +INF)))
           ?= OBTAIN-BY-ASKING6213 ((AGENT JOE) (OBJECT SALT) (TIME #(TIME -INF 4 5 +INF))
(PRETIME #(TIME -INF 4 -INF +INF)))
                S1 -> REQUEST6164 ((SPEAKER JOE) (HEARER SALLY) (REQGOAL (GAVE SALLY JOE SA
LT)) (TIME #(TIME 4 4 5 5)))
                     ?= INDIRECT-REQUEST6114 ((SPEAKER JOE) (HEARER SALLY) (REQGOAL (GAVE S
ALLY JOE SALT)) (TIME #(TIME 4 4 5 5)))
                          S -> SURFACE-QUESTION6095 ((SPEAKER JOE) (HEARER SALLY) (CONTENT
(CAN SALLY (GAVE SALLY JOE SALT))) (TIME #(TIME 4 4 5 5)))
  (SURFACE-QUESTION6095 INDIRECT-REQUEST6114 REQUEST6164 OBTAIN-BY-ASKING6213 OBTAIN6267 EN
