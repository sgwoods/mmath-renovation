    (at box1 loc13)
    (inroom box1 room6)
    (at box2 loc14)
    (inroom box2 room6)
    (at box3 loc19)
    (inroom box3 room4)
))

;goal state
;
(setq goal '(
 (inroom robot room1)
            ))

;***************************************************************************
; abtweak domain part - refered to only in abtweak
;***************************************************************************

(setq *critical-list* '(
   (4  (armempty) (not armempty) 
       (is-location $) (carriable $) (is-door-loc $ $) (is-door $ $ $)
       (location-inroom $ $) (is-object $) (is-room $) (pushable $) (carriable $) )
   (3  (inroom $ $) )
   (2  (at     $ $) )
   (1  (open $) (not open $) )
   (0  (holding $) )
))

(setq *k-list* '(0 1 2 3 4))  ; simple default

(setq *top-down-levels*     
'(
  4
  3
  2
  1
  0
))

;******** NEW OPERATOR MOTIVATION LISTS **********
;
; invoke via switch :motive-discard t
;
; How SHOULD we NOT achieve each goal (via new establishers) ?

(setq *not-motive* '(
( (inroom robot $) ( push-thru-dr carry-thru-dr ) )
))


