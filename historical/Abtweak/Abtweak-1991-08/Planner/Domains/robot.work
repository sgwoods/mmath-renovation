(princ "10") (terpri)
(setq s10-1 (caar s10))
(setq s11 (s s10-1))
(princ "11") (terpri)
(setq s11-2 (car (second s11)))
(setq s12 (s s11-2))
(princ "12") (terpri)
(setq s12-1 (caar s12))
(setq s13 (s s12-1))
(princ "13") (terpri)
(setq s13-1 (caar s13))
(setq s14 (s s13-1))
(princ "14") (terpri)
(setq s14-1 (caar s14))
