(princ "5") (terpri)
(setq s5-1 (caar s5))
(setq s6 (s s5-1))
(princ "6") (terpri)
(setq s6-5 (car (fifth s6)))
(setq s7 (s s6-5))
(princ "7") (terpri)
(setq s7-3 (car (third s7)))
(setq s8 (s s7-3))
(princ "8") (terpri)
(setq s8-4 (car (fourth s8)))
