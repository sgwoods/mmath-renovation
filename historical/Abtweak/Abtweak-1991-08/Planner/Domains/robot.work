(defun sh (lplan) (show (car lplan)))
(defun s (p) (successors&costs p))

(setq goal '((at robot loc20) (holding obj3)) )
(setq i (make-initial-plan initial goal))
(setq s1 (s i))  
(princ "1") (terpri)
(setq s1-1 (caar s1))
(setq s2 (s s1-1))
(princ "2") (terpri)
(setq s2-1 (caar s2))
(setq s3 (s s2-1))
